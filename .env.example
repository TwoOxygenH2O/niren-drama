# Niren Drama environment template
# Copy this file to `.env` and fill real local values.
# Do not commit `.env` or any private API keys.

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=niren_drama
DB_USER=root
DB_PASSWORD=<CHANGE_ME_DB_PASSWORD>

# JWT
# Use a private random value with at least 32 characters.
JWT_SECRET=<CHANGE_ME_32_BYTES_MIN>

# Secret used to encrypt model provider API keys before storing them in MySQL.
# If blank, the application falls back to JWT_SECRET.
NIREN_CONFIG_ENCRYPTION_KEY=

# Uploads
UPLOAD_PATH=./uploads
BASE_URL=http://localhost:8080

# Text generation
AI_TEXT_PROVIDER=openai
AI_TEXT_BASE_URL=https://api.openai.com/v1
AI_TEXT_API_KEY=
AI_TEXT_MODEL=gpt-4o

# Optional CASR visual analysis 2.0 VLM review.
# Leave blank to use the default text provider when it is vision-capable.
NIREN_VISUAL_REVIEW_ENABLED=true
NIREN_VISUAL_REVIEW_BASE_URL=
NIREN_VISUAL_REVIEW_API_KEY=
NIREN_VISUAL_REVIEW_MODEL=
NIREN_VISUAL_REVIEW_MAX_KEYFRAMES=3

# Image generation
AI_IMAGE_PROVIDER=openai
AI_IMAGE_BASE_URL=https://api.openai.com/v1
AI_IMAGE_API_KEY=
AI_IMAGE_MODEL=dall-e-3

# Video generation
AI_VIDEO_PROVIDER=comfyui
AI_VIDEO_BASE_URL=http://127.0.0.1:8188
AI_VIDEO_API_KEY=
AI_VIDEO_MODEL=wan2.2_i2v_high_noise_14B_fp8_scaled.safetensors
COMFYUI_ROOT=D:\Projects\ComfyUI-aki\ComfyUI

# Wan2.2 LoRA training
NIREN_WAN22_TRAINING_ROOT=./wan22-video-training
NIREN_WAN22_TRAINER_ROOT=
NIREN_WAN22_ACCELERATE_COMMAND=accelerate
NIREN_WAN22_MODEL_PATHS_JSON=
NIREN_WAN22_COMMAND_TEMPLATE=
NIREN_WAN22_OUTPUT_DIR=wan22-video-training/checkpoints

# TTS
AI_TTS_PROVIDER=volcengine
AI_TTS_BASE_URL=
AI_TTS_API_KEY=
AI_TTS_VOICE=zh_female_qingxin

# FFmpeg
FFMPEG_PATH=ffmpeg
NIREN_FFMPEG_SEARCH_DIRS=

# Optional public object storage
NIREN_COS_ENABLED=false
NIREN_COS_SECRET_ID=
NIREN_COS_SECRET_KEY=
NIREN_COS_REGION=ap-beijing
NIREN_COS_BUCKET=
NIREN_COS_PUBLIC_BASE_URL=

# Cost controls
COST_IMAGE_REUSE=true
COST_QUALITY_TIER=standard
COST_VIDEO_AI_ENABLED=false
COST_VIDEO_AI_RATIO=0.3
COST_PREVIEW_RESOLUTION=512x512
