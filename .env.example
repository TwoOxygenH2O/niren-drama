# ===================================================
# 泥人剧场 · 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ===================================================

# ——— MySQL 数据库 ———
DB_HOST=localhost
DB_PORT=3306
DB_NAME=niren_drama
DB_USER=root
DB_PASSWORD=NirenDrama2024!

# ——— Redis ———
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ——— JWT ———
# 生产环境必须修改为强密钥（建议64位随机字符串）
JWT_SECRET=niren-drama-jwt-secret-very-long-secure-key-change-in-production

# ——— 文件上传 ———
UPLOAD_PATH=./uploads
BASE_URL=http://localhost:8080

# ——— AI 文本大模型（剧本生成 / 分镜拆解）———
AI_TEXT_PROVIDER=openai
AI_TEXT_BASE_URL=https://api.openai.com/v1
AI_TEXT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_TEXT_MODEL=gpt-4o

# ——— AI 图像生成（角色图 / 场景图 / 分镜图）———
AI_IMAGE_PROVIDER=openai
AI_IMAGE_BASE_URL=https://api.openai.com/v1
AI_IMAGE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_IMAGE_MODEL=dall-e-3

# ——— AI 视频生成（可选，后续版本支持）———
AI_VIDEO_PROVIDER=kling
AI_VIDEO_BASE_URL=
AI_VIDEO_API_KEY=

# ——— TTS 语音合成 ———
AI_TTS_PROVIDER=volcengine
AI_TTS_BASE_URL=
AI_TTS_API_KEY=
AI_TTS_VOICE=zh_female_qingxin

# ——— FFmpeg（视频合成，需本地安装）———
FFMPEG_PATH=ffmpeg

# ——— 成本优化配置 ———
# 图片复用：相同场景+角色+镜头角度复用已生成图片
COST_IMAGE_REUSE=true
# 质量档次：preview(低成本预览) / standard(标准) / premium(高品质)
COST_QUALITY_TIER=standard
# 是否启用AI视频生成（极大增加成本，默认关闭使用FFmpeg合成）
COST_VIDEO_AI_ENABLED=false
# AI视频仅用于关键动态镜头的比例（0.3=30%镜头用AI视频）
COST_VIDEO_AI_RATIO=0.3
# 预览模式图片分辨率
COST_PREVIEW_RESOLUTION=512x512
